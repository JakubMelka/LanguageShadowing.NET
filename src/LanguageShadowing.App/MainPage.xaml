<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:viewModels="clr-namespace:LanguageShadowing.Application.ViewModels;assembly=LanguageShadowing.Application"
             xmlns:controls="clr-namespace:LanguageShadowing.App.Controls"
             xmlns:converters="clr-namespace:LanguageShadowing.App.Converters"
             xmlns:models="clr-namespace:LanguageShadowing.Core.Models;assembly=LanguageShadowing.Core"
             x:Class="LanguageShadowing.App.MainPage"
             x:DataType="viewModels:MainViewModel">
    <ContentPage.Resources>
        <converters:HexToColorConverter x:Key="HexToColorConverter" />
    </ContentPage.Resources>

    <Grid Padding="24"
          BackgroundColor="{DynamicResource PageBackground}"
          ColumnDefinitions="1.7*,1.05*"
          RowDefinitions="Auto,1.2*,Auto,1*"
          ColumnSpacing="18"
          RowSpacing="18">
        <Border Grid.Row="0"
                Grid.ColumnSpan="2"
                Style="{StaticResource CardBorderStyle}"
                Margin="0"
                Padding="16,14">
            <VerticalStackLayout Spacing="2">
                <Label Text="Language Shadowing"
                       FontSize="24"
                       FontAttributes="Bold" />
                <Label Text="Shadow spoken phrases, monitor recognition, and tune the voice profile in one pass."
                       FontSize="12"
                       TextColor="{DynamicResource SecondaryText}" />
            </VerticalStackLayout>
        </Border>

        <Border Grid.Row="1"
                Grid.Column="0"
                Style="{StaticResource CardBorderStyle}"
                Margin="0"
                VerticalOptions="Fill">
            <Grid RowDefinitions="Auto,Auto,*" RowSpacing="12" VerticalOptions="Fill">
                <Label Text="Source text" FontAttributes="Bold" FontSize="18" />
                <Label Grid.Row="1"
                       Text="Enter the text that should be spoken by the selected voice."
                       TextColor="{DynamicResource SecondaryText}" />
                <Editor x:Name="SourceEditor"
                        Grid.Row="2"
                        Text="{Binding SourceText}"
                        IsEnabled="{Binding CanEditSourceText}"
                        AutoSize="Disabled"
                        MinimumHeightRequest="220"
                        VerticalOptions="FillAndExpand"
                        Placeholder="For example: Today I am practicing pronunciation by shadowing each sentence." />
            </Grid>
        </Border>

        <Border Grid.Row="1"
                Grid.RowSpan="3"
                Grid.Column="1"
                Style="{StaticResource CardBorderStyle}"
                Margin="0">
            <ScrollView>
                <VerticalStackLayout Spacing="16">
                    <Label Text="Speech setup" FontAttributes="Bold" FontSize="18" />
                    <Label Text="Choose the synthesis engine, preferred voice, and playback profile." TextColor="{DynamicResource SecondaryText}" />

                    <VerticalStackLayout Spacing="6">
                        <Label Text="Engine" FontAttributes="Bold" />
                        <Picker ItemsSource="{Binding Engines}"
                                SelectedItem="{Binding SelectedEngineName}"
                                Title="Choose an engine" />
                    </VerticalStackLayout>

                    <VerticalStackLayout Spacing="6">
                        <Label Text="Voice" FontAttributes="Bold" />
                        <Picker ItemsSource="{Binding Voices}"
                                SelectedItem="{Binding SelectedVoice}"
                                Title="Choose a voice">
                            <Picker.ItemDisplayBinding>
                                <Binding Path="SelectionLabel" x:DataType="models:VoiceInfo" />
                            </Picker.ItemDisplayBinding>
                        </Picker>
                    </VerticalStackLayout>

                    <Grid ColumnDefinitions="*,Auto" RowDefinitions="Auto,Auto,Auto" ColumnSpacing="12" RowSpacing="14">
                        <VerticalStackLayout Grid.Row="0" Spacing="6">
                            <Label Text="Speed" FontAttributes="Bold" />
                            <Slider Minimum="0.5" Maximum="2" Value="{Binding SpeechRate}" />
                        </VerticalStackLayout>
                        <Border Grid.Row="0"
                                Grid.Column="1"
                                Padding="12,8"
                                BackgroundColor="{DynamicResource SurfaceMuted}"
                                StrokeThickness="0"
                                VerticalOptions="End">
                            <Label Text="{Binding SpeechRateDisplay}" FontAttributes="Bold" />
                        </Border>

                        <VerticalStackLayout Grid.Row="1" Spacing="6">
                            <Label Text="Pitch" FontAttributes="Bold" />
                            <Slider Minimum="0" Maximum="2" Value="{Binding SpeechPitch}" />
                        </VerticalStackLayout>
                        <Border Grid.Row="1"
                                Grid.Column="1"
                                Padding="12,8"
                                BackgroundColor="{DynamicResource SurfaceMuted}"
                                StrokeThickness="0"
                                VerticalOptions="End">
                            <Label Text="{Binding SpeechPitchDisplay}" FontAttributes="Bold" />
                        </Border>

                        <VerticalStackLayout Grid.Row="2" Spacing="6">
                            <Label Text="Volume" FontAttributes="Bold" />
                            <Slider Minimum="0" Maximum="1" Value="{Binding SpeechVolume}" />
                        </VerticalStackLayout>
                        <Border Grid.Row="2"
                                Grid.Column="1"
                                Padding="12,8"
                                BackgroundColor="{DynamicResource SurfaceMuted}"
                                StrokeThickness="0"
                                VerticalOptions="End">
                            <Label Text="{Binding SpeechVolumeDisplay}" FontAttributes="Bold" />
                        </Border>
                    </Grid>

                    <Label Text="{Binding RecognitionAvailabilityText}"
                           TextColor="{DynamicResource SecondaryText}"
                           FontSize="12" />
                    <HorizontalStackLayout Spacing="10"
                                           IsVisible="{Binding ShowRecognitionSettingsButtons}">
                        <Button Text="Speech Settings"
                                Style="{StaticResource ToolbarButtonStyle}"
                                Command="{Binding OpenSpeechPrivacySettingsCommand}" />
                        <Button Text="Microphone Settings"
                                Style="{StaticResource ToolbarButtonStyle}"
                                Command="{Binding OpenMicrophonePrivacySettingsCommand}" />
                    </HorizontalStackLayout>

                    <BoxView HeightRequest="1"
                             Margin="0,4"
                             Color="{DynamicResource BorderColor}" />

                    <VerticalStackLayout Spacing="10">
                        <Label Text="Appearance" FontAttributes="Bold" FontSize="18" />
                        <Label Text="Switch between light, dark, or automatic theme based on the system preference."
                               TextColor="{DynamicResource SecondaryText}" />
                        <Picker ItemsSource="{Binding ThemeOptions}"
                                SelectedItem="{Binding SelectedThemeOption}"
                                Title="Choose a theme" />
                    </VerticalStackLayout>
                </VerticalStackLayout>
            </ScrollView>
        </Border>

        <Border Grid.Row="2"
                Grid.Column="0"
                Style="{StaticResource CardBorderStyle}"
                Margin="0">
            <VerticalStackLayout Spacing="16">
                <Grid ColumnDefinitions="Auto,Auto,Auto,Auto,Auto,*" ColumnSpacing="10">
                    <Button Text="Reset" Style="{StaticResource ToolbarButtonStyle}" Command="{Binding ResetCommand}" />
                    <Button Grid.Column="1" Text="Pause" Style="{StaticResource ToolbarButtonStyle}" Command="{Binding PauseCommand}" />
                    <Button Grid.Column="2" Text="Play" Style="{StaticResource ToolbarPrimaryButtonStyle}" Command="{Binding PlayCommand}" />
                    <Button Grid.Column="3" Text="Stop" Style="{StaticResource ToolbarButtonStyle}" Command="{Binding StopCommand}" />
                    <Button Grid.Column="4" Text="Rewind" Style="{StaticResource ToolbarButtonStyle}" Command="{Binding RewindCommand}" />
                </Grid>

                <Grid RowDefinitions="Auto,Auto,Auto" RowSpacing="8">
                    <controls:WaveformView Grid.Row="0"
                                           Samples="{Binding WaveformSamples}"
                                           Progress="{Binding ProgressRatio}" />
                    <Slider x:Name="ProgressSlider"
                            Grid.Row="0"
                            Margin="8,0"
                            Minimum="0"
                            DragStarted="OnProgressDragStarted"
                            DragCompleted="OnProgressDragCompleted"
                            BackgroundColor="Transparent" />
                    <Grid Grid.Row="1" ColumnDefinitions="Auto,*,Auto">
                        <Label Text="{Binding PositionText}" TextColor="{DynamicResource SecondaryText}" />
                        <BoxView Grid.Column="1" BackgroundColor="Transparent" />
                        <Label Grid.Column="2" Text="{Binding DurationText}" TextColor="{DynamicResource SecondaryText}" />
                    </Grid>
                    <Label Grid.Row="2"
                           Text="{Binding StatusMessage}"
                           TextColor="{DynamicResource SecondaryText}"
                           FontSize="12" />
                </Grid>
            </VerticalStackLayout>
        </Border>

        <Border Grid.Row="3"
                Grid.Column="0"
                Style="{StaticResource CardBorderStyle}"
                Margin="0"
                VerticalOptions="Fill">
            <Grid RowDefinitions="Auto,*,Auto" RowSpacing="14" VerticalOptions="Fill">
                <Grid ColumnDefinitions="*,Auto,Auto" ColumnSpacing="12">
                    <Label Text="Recognized transcript" FontAttributes="Bold" FontSize="18" />
                    <Border Grid.Column="1"
                            Padding="14,8"
                            BackgroundColor="{Binding ScoreColorHex, Converter={StaticResource HexToColorConverter}}"
                            StrokeThickness="0">
                        <Border.StrokeShape>
                            <RoundRectangle CornerRadius="14" />
                        </Border.StrokeShape>
                        <Label Text="{Binding ScoreText}" TextColor="White" FontAttributes="Bold" />
                    </Border>
                    <Button Grid.Column="2" Text="Clear" Command="{Binding ClearRecognizedCommand}" />
                </Grid>

                <Editor x:Name="RecognizedEditor"
                        Grid.Row="1"
                        Text="{Binding RecognizedText}"
                        IsReadOnly="True"
                        AutoSize="Disabled"
                        MinimumHeightRequest="180"
                        VerticalOptions="FillAndExpand"
                        Placeholder="The microphone will continuously append recognized text." />
                <Label Grid.Row="2" Text="{Binding ShadowingSummary}" TextColor="{DynamicResource SecondaryText}" />
            </Grid>
        </Border>
    </Grid>
</ContentPage>

