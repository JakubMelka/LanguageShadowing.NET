<?xml version="1.0" encoding="utf-8" ?>
<Application xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="LanguageShadowing.App.App">
    <Application.Resources>
        <ResourceDictionary>
            <Color x:Key="PageBackground">#F4F7FB</Color>
            <Color x:Key="CardBackground">#FFFFFF</Color>
            <Color x:Key="SurfaceMuted">#EEF2F8</Color>
            <Color x:Key="SurfaceHover">#E2E8F2</Color>
            <Color x:Key="BorderColor">#D6DEEA</Color>
            <Color x:Key="BorderHoverColor">#C1CBDC</Color>
            <Color x:Key="PrimaryText">#1B2430</Color>
            <Color x:Key="SecondaryText">#667286</Color>
            <Color x:Key="AccentColor">#2D7FF9</Color>
            <Color x:Key="AccentHoverColor">#1F6EE3</Color>
            <Color x:Key="AccentSoft">#DCE9FF</Color>
            <Color x:Key="AccentSoftHover">#C8DCFF</Color>

            <Style TargetType="ContentPage">
                <Setter Property="BackgroundColor" Value="{DynamicResource PageBackground}" />
            </Style>

            <Style x:Key="CardBorderStyle" TargetType="Border">
                <Setter Property="BackgroundColor" Value="{DynamicResource CardBackground}" />
                <Setter Property="Stroke" Value="{DynamicResource BorderColor}" />
                <Setter Property="StrokeThickness" Value="1" />
                <Setter Property="Padding" Value="20" />
                <Setter Property="Margin" Value="0,0,0,18" />
                <Setter Property="StrokeShape">
                    <Setter.Value>
                        <RoundRectangle CornerRadius="24" />
                    </Setter.Value>
                </Setter>
            </Style>

            <Style TargetType="Label">
                <Setter Property="TextColor" Value="{DynamicResource PrimaryText}" />
            </Style>

            <Style TargetType="Button">
                <Setter Property="BackgroundColor" Value="{DynamicResource AccentSoft}" />
                <Setter Property="TextColor" Value="{DynamicResource AccentColor}" />
                <Setter Property="CornerRadius" Value="14" />
                <Setter Property="Padding" Value="16,10" />
                <Setter Property="FontAttributes" Value="Bold" />
                <Setter Property="VisualStateManager.VisualStateGroups">
                    <VisualStateGroupList>
                        <VisualStateGroup x:Name="CommonStates">
                            <VisualState x:Name="Normal" />
                            <VisualState x:Name="PointerOver">
                                <VisualState.Setters>
                                    <Setter Property="BackgroundColor" Value="{DynamicResource AccentSoftHover}" />
                                </VisualState.Setters>
                            </VisualState>
                            <VisualState x:Name="Disabled" />
                        </VisualStateGroup>
                    </VisualStateGroupList>
                </Setter>
            </Style>

            <Style x:Key="ToolbarButtonStyle" TargetType="Button">
                <Setter Property="BackgroundColor" Value="{DynamicResource SurfaceMuted}" />
                <Setter Property="TextColor" Value="{DynamicResource PrimaryText}" />
                <Setter Property="CornerRadius" Value="16" />
                <Setter Property="Padding" Value="18,12" />
                <Setter Property="FontAttributes" Value="Bold" />
                <Setter Property="BorderColor" Value="{DynamicResource BorderColor}" />
                <Setter Property="BorderWidth" Value="1" />
                <Setter Property="VisualStateManager.VisualStateGroups">
                    <VisualStateGroupList>
                        <VisualStateGroup x:Name="CommonStates">
                            <VisualState x:Name="Normal" />
                            <VisualState x:Name="PointerOver">
                                <VisualState.Setters>
                                    <Setter Property="BackgroundColor" Value="{DynamicResource SurfaceHover}" />
                                    <Setter Property="BorderColor" Value="{DynamicResource BorderHoverColor}" />
                                </VisualState.Setters>
                            </VisualState>
                            <VisualState x:Name="Disabled" />
                        </VisualStateGroup>
                    </VisualStateGroupList>
                </Setter>
            </Style>

            <Style x:Key="ToolbarPrimaryButtonStyle" TargetType="Button" BasedOn="{StaticResource ToolbarButtonStyle}">
                <Setter Property="BackgroundColor" Value="{DynamicResource AccentColor}" />
                <Setter Property="TextColor" Value="White" />
                <Setter Property="BorderColor" Value="{DynamicResource AccentColor}" />
                <Setter Property="VisualStateManager.VisualStateGroups">
                    <VisualStateGroupList>
                        <VisualStateGroup x:Name="CommonStates">
                            <VisualState x:Name="Normal" />
                            <VisualState x:Name="PointerOver">
                                <VisualState.Setters>
                                    <Setter Property="BackgroundColor" Value="{DynamicResource AccentHoverColor}" />
                                    <Setter Property="BorderColor" Value="{DynamicResource AccentHoverColor}" />
                                </VisualState.Setters>
                            </VisualState>
                            <VisualState x:Name="Disabled" />
                        </VisualStateGroup>
                    </VisualStateGroupList>
                </Setter>
            </Style>

            <Style TargetType="Editor">
                <Setter Property="BackgroundColor" Value="{DynamicResource SurfaceMuted}" />
                <Setter Property="TextColor" Value="{DynamicResource PrimaryText}" />
                <Setter Property="PlaceholderColor" Value="{DynamicResource SecondaryText}" />
                <Setter Property="AutoSize" Value="TextChanges" />
                <Setter Property="Margin" Value="0,10,0,0" />
            </Style>

            <Style TargetType="Picker">
                <Setter Property="BackgroundColor" Value="{DynamicResource SurfaceMuted}" />
                <Setter Property="TextColor" Value="{DynamicResource PrimaryText}" />
                <Setter Property="TitleColor" Value="{DynamicResource SecondaryText}" />
            </Style>

            <Style TargetType="Slider">
                <Setter Property="ThumbColor" Value="{DynamicResource AccentColor}" />
                <Setter Property="MinimumTrackColor" Value="#332D7FF9" />
                <Setter Property="MaximumTrackColor" Value="#00FFFFFF" />
            </Style>
        </ResourceDictionary>
    </Application.Resources>
</Application>
